# syntax=docker/dockerfile:1.7
#
# Restate worker — hosts the `Notation` virtual object's two timelines
# (questionnaire + workflow). Built as a static musl binary so the
# runtime image can be `gcr.io/distroless/cc` (the SDK pulls in TLS,
# which needs `cc`-flavored distroless rather than `static`).
#
# Image conventions match Containerfile.web (the `web` image): same Rust
# toolchain pin (rust-toolchain.toml → 1.96.0), same musl target,
# same distroless base family.

FROM rust:1.96-bookworm AS builder

# The musl target is chosen from BuildKit's automatic TARGETARCH so the
# SAME Containerfile builds a native aarch64 image on an Apple-Silicon dev
# laptop (for local KIND) and an x86_64 image in CI / for GKE Autopilot
# (amd64). Building x86_64-musl on an arm64 host is a cross-compile that
# breaks aws-lc-sys's C build (`musl-gcc` rejects the x86-only `-m64`);
# the native target sidesteps it. `navigator power-push` forces
# `--platform linux/amd64`, so prod images are always amd64.
ARG TARGETARCH
RUN apt-get update \
    && apt-get install -y --no-install-recommends musl-tools pkg-config \
    && rm -rf /var/lib/apt/lists/* \
    && case "$TARGETARCH" in \
         amd64) echo x86_64-unknown-linux-musl  > /tmp/rust-target ;; \
         arm64) echo aarch64-unknown-linux-musl > /tmp/rust-target ;; \
         *) echo "unsupported TARGETARCH: ${TARGETARCH:-unset}" >&2; exit 1 ;; \
       esac

WORKDIR /src

# Copy the full workspace in one layer and build. The previous
# stub-prime variant of this Containerfile drifted every time a new
# workspace member (archives, lsp) or BDD runner landed — the
# real builder couldn't see them and `cargo build` failed at
# resolve time. Single COPY + build mirrors the `web` Containerfile
# and still benefits from layer caching when nothing changes.
#
# `rust-toolchain.toml` must land BEFORE `rustup target add`: the override
# pins a specific 1.96.0 toolchain that rustup re-syncs the first time cargo
# runs in this dir. Adding the target beforehand (against the base image's
# default toolchain) leaves the re-synced toolchain without the musl std,
# and `cargo build --target …-musl` then fails with `can't find crate for
# std`. Adding it here attaches the target to the toolchain the build uses.
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
RUN rustup target add "$(cat /tmp/rust-target)"
COPY rules             rules
COPY store             store
COPY repos             repos
COPY import            import
COPY cli               cli
COPY web               web
COPY views             views
COPY README.md         README.md
COPY telemetry         telemetry
COPY forms             forms
COPY workflows         workflows
COPY workflows-service workflows-service
COPY cloud             cloud
COPY mcp               mcp
COPY features          features
COPY lsp               lsp
COPY live-inquiry      live-inquiry
COPY pdf               pdf
COPY templates templates
COPY archives          archives
COPY statutes          statutes
COPY billing           billing
COPY billing-workflows billing-workflows

RUN cargo build --release --target "$(cat /tmp/rust-target)" -p workflows-service \
    && cp "target/$(cat /tmp/rust-target)/release/workflows-service" /usr/local/bin/workflows-service

# ---------- Stage 2: runtime ----------
#
# `distroless/cc` (vs `static`) so the binary's TLS dep — pulled in by
# `restate-sdk` via reqwest — finds its dynamic loader. Same nonroot
# user as the web image.

FROM gcr.io/distroless/cc-debian12:nonroot AS runtime

WORKDIR /app

COPY --from=builder \
    /usr/local/bin/workflows-service \
    /app/workflows-service

# The worker reads the database URL + Restate listen address from
# env. Defaults match the in-cluster Service names; override in the
# RestateDeployment CR.
ENV WORKFLOWS_SERVICE_LISTEN=0.0.0.0:9080

# Identify the release. The daily `deploy.yml` passes `--build-arg
# RELEASE_TAG=$YY.M.D`; `telemetry::init` reads `NAVIGATOR_RELEASE_TAG`
# and tags every span/metric/log with `service.version`, so the headless
# worker self-reports which release it is — the counterpart to `web`'s
# `GET /version`. A local build (no build-arg) reports `unknown`.
ARG RELEASE_TAG=unknown
ENV NAVIGATOR_RELEASE_TAG=$RELEASE_TAG

EXPOSE 9080

USER nonroot:nonroot

ENTRYPOINT ["/app/workflows-service"]
