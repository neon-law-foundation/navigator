# Navigator — environment variables (canonical reference)
#
# Every variable the workspace reads, grouped by subsystem. Copy this
# file to `.env`, fill in the blanks for your deployment, and run any
# Navigator binary — `dotenvy::dotenv()` is wired into `web`, `cli`,
# the `navigator` CLI, `workflows-service`, and `archives` so the values are
# picked up automatically.
#
# Conventions:
#   - Variables marked `# (secret)` MUST NOT be committed. The repo's
#     `.gitignore` excludes `.env`, `.env.*`, and `dist-oss/` already.
#   - Variables marked `# (required in prod)` are checked by
#     `web::config::enforce_prod_invariants` at startup; missing values
#     crash the binary loudly instead of silently degrading.
#   - Variables marked `# (optional)` have sensible defaults documented
#     next to them.
#   - Anywhere you see `YOUR_*`, substitute your own identifier.
#   - Third-party API integrations (DocuSign e-signature today; Xero
#     accounting/billing next) use a SEPARATE vendor account per
#     environment — a development/sandbox account for local dev and a
#     production account for prod. Selection is by env FILE, not an
#     `APP_ENV` flag (which the SQLite cutover removed): the sandbox
#     credentials live in `.env` (auto-loaded on startup), the production
#     credentials in `.env.production` (gitignored by `.env.*`). Both
#     files use the SAME variable names — the file is the namespace.
#     Switch by sourcing the production file over the defaults:
#         set -a; source .env.production; set +a
#     In the deployed cluster the production values arrive via the K8s
#     Secret (Secret Manager → navigator-web-secrets), so no file is
#     sourced there. A vendor left entirely unconfigured falls back to an
#     in-process stub that performs no external calls — the safe default,
#     so a fork can run and self-test without touching any real account.
#
# For a guided walk-through of provisioning a fresh GCP project against
# this file, see `docs/oss-install.md`. For other clouds, see
# `docs/multi-cloud.md`.
#
# SECRETS STORE: NeonLaw keeps the values for these variables in Doppler
# (project `navigator`, configs `dev` / `prd`) and injects them with
# `doppler run -- cargo run -p web`. This file stays the canonical,
# committed CONTRACT — every name and annotation — while Doppler holds
# the values. Doppler is OPTIONAL: nothing in the source tree requires
# it, so a fork can ignore Doppler and use this `.env` directly. Full
# workflow (local `doppler run`, prod render into Secret Manager,
# rotation, adding a key): `docs/secrets-doppler.md`.

# ---------------------------------------------------------------------
# Database — Postgres (Cloud SQL, RDS, self-hosted, KIND, …)
# ---------------------------------------------------------------------

# Postgres connection URL. The workspace speaks vanilla Postgres via
# SeaORM, so anything that exposes a Postgres wire endpoint works.
# Local KIND: `postgres://navigator:navigator@localhost:5432/navigator`
DATABASE_URL=

# ---------------------------------------------------------------------
# Object storage — GCS, S3-via-fake-gcs, local filesystem
# ---------------------------------------------------------------------

# `fs` for a local directory (dev), `gcs` for Google Cloud Storage or
# any GCS-compatible API. The `gcs` backend speaks the GCS REST API, so
# `fake-gcs-server` (KIND) works without any code change.
NAVIGATOR_STORAGE_BACKEND=fs

# Private documents bucket — `web` writes client `blobs/<sha>` here.
# Preferred over NAVIGATOR_STORAGE_BUCKET below; if set, it wins. Keep
# this distinct from the public NAVIGATOR_ASSETS_BUCKET so confidential
# client documents never land in a publicly-readable bucket. By
# convention `<project>-documents`. No `gs://` prefix.
# NAVIGATOR_DOCUMENTS_BUCKET=YOUR_PROJECT_ID-documents

# Generic bucket name (required when backend=gcs and
# NAVIGATOR_DOCUMENTS_BUCKET is unset). The fallback the `archives`
# cron and the KIND / navigator dev loops point at their own bucket. For
# GCS, this is just the bucket — no `gs://` prefix.
NAVIGATOR_STORAGE_BUCKET=

# Override the GCS endpoint for `fake-gcs-server` or an S3 gateway.
# Leave unset to talk to real GCS.
# NAVIGATOR_STORAGE_ENDPOINT=http://fake-gcs-server.navigator.svc.cluster.local:4443

# Filesystem root (required when backend=fs). Relative paths resolve
# against the binary's working directory.
NAVIGATOR_STORAGE_FS_ROOT=./var/storage

# ---------------------------------------------------------------------
# Public assets bucket — responsive photography
# ---------------------------------------------------------------------

# The public bucket that serves the marketing photography, distinct from
# the documents bucket (NAVIGATOR_DOCUMENTS_BUCKET) above. `cli assets
# upload` pushes the built variant tree here (key `img/<slug>/...`) with
# a bounded Cache-Control; production grants `allUsers:objectViewer` on
# this bucket ONLY. By convention `<project>-assets`. No `gs://` prefix.
# NAVIGATOR_ASSETS_BUCKET=YOUR_PROJECT_ID-assets

# Base URL every photo `<picture>`/preload path resolves against (the
# `views::assets::asset_url` seam). Unset, it defaults to `/public` so
# KIND / `cargo test` / OSS forks serve the crate-bundled variants with
# zero config. Point it at the public assets bucket in production; when
# set to an absolute origin, `web` adds that origin to the CSP `img-src`
# automatically so the browser does not block CDN photos. Vendored
# JS/CSS stays same-origin on `/public` regardless.
# NAVIGATOR_ASSET_BASE_URL=https://storage.googleapis.com/YOUR_PROJECT_ID-assets

# ---------------------------------------------------------------------
# HTTP server — `web` binary
# ---------------------------------------------------------------------

# TCP port `web` binds to. Default: 3001.
PORT=3001

# Canonical hostname. Used by the redirect path and by absolute URL
# generation in emails. No protocol, no path — e.g. `example.com`.
CANONICAL_HOST=

# Base URL the app uses for outbound links (verification emails,
# webhook callbacks, etc.). Include scheme. Example:
# `https://app.example.com`.
NAV_BASE_URL=

# ---------------------------------------------------------------------
# Brand — copy that appears in headers, footers, and page titles
# ---------------------------------------------------------------------

# Firm / organization name (shown in the header and page titles).
# Default if unset: "Neon Law" (NeonLaw's canonical deployment). OSS
# forks override here with their own firm name.
NAVIGATOR_BRAND_FIRM=Neon Law

# Nonprofit / foundation name (separate brand surface for the
# access-to-justice arm). Default: "Neon Law Foundation".
NAVIGATOR_BRAND_FOUNDATION=Neon Law Foundation

# Primary domain shown in copy + email signatures. No protocol.
# Default: NeonLaw uses `neonlaw.com`; OSS forks substitute their
# own.
NAVIGATOR_PRIMARY_DOMAIN=neonlaw.com

# Support / contact email surfaced on contact pages. Default:
# "support@neonlaw.com". OSS forks override.
NAVIGATOR_SUPPORT_EMAIL=support@neonlaw.com

# Firm consultation booking calendar — the link behind every "Book a
# Consultation" CTA (home + service-page footers, the service hero, the
# firm contact card). Default: NeonLaw's Google Calendar appointment
# page. OSS forks point this at their own scheduler.
NAVIGATOR_CONSULTATION_URL=https://calendar.app.google/GueqKHiAuqXEwkRG8

# Where the footer's "Terms" / "Privacy" links point. Default: the
# in-app `/terms` and `/privacy` pages (NeonLaw's bundled copy). A
# white-label deploy that hosts its own legal pages on its own site sets
# these to those off-site URLs, so Navigator never serves a deployer's
# binding legal text. Required when NAVIGATOR_PORTAL_ONLY is on.
NAVIGATOR_TERMS_URL=/terms
NAVIGATOR_PRIVACY_URL=/privacy

# White-label "portal-only" mode (`true` / `1`). When on, `web` mounts
# only the application surface — /portal, auth, /api, /mcp, the git
# transport, webhooks, the health probes, and the legal pages — and
# drops the entire public marketing + Foundation site; `/` redirects to
# /portal. For a firm that runs its own marketing website (WordPress, a
# marketing team) and only wants Navigator to be the client portal +
# workflow engine. Default: unset (the full public site is served).
NAVIGATOR_PORTAL_ONLY=

# ---------------------------------------------------------------------
# OIDC / Browser-side auth — Keycloak (KIND), Google, Auth0, Okta, …
# ---------------------------------------------------------------------
#
# Authentication is OIDC-spec-compliant: the workspace fetches the
# issuer's `.well-known/openid-configuration` and reads the
# authorization / token / jwks endpoints from there. Swapping IdPs is
# four env vars, no code change.
#
# Recipe — pick ONE block and uncomment the four lines.
#
# (1) Keycloak in KIND (the local-dev default; `navigator start-dev-server` writes these
#     into `.devx/env` automatically — only override here if you need
#     a different realm/client).
#   OAUTH_ISSUER_URL=http://localhost:30080/keycloak/realms/navigator
#   OAUTH_CLIENT_ID=navigator-web
#   OAUTH_CLIENT_SECRET=navigator-web-secret
#   OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
#
# (2) Google Identity (Cloud Identity / Workspace).
#   OAUTH_ISSUER_URL=https://accounts.google.com
#   OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
#   OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
#   OAUTH_REDIRECT_URI=https://app.example.com/auth/callback
#
# (3) Auth0.
#   OAUTH_ISSUER_URL=https://YOUR_TENANT.us.auth0.com/
#   OAUTH_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
#   OAUTH_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
#   OAUTH_REDIRECT_URI=https://app.example.com/auth/callback
#
# (4) Okta.
#   OAUTH_ISSUER_URL=https://YOUR_DOMAIN.okta.com/oauth2/default
#   OAUTH_CLIENT_ID=YOUR_OKTA_CLIENT_ID
#   OAUTH_CLIENT_SECRET=YOUR_OKTA_CLIENT_SECRET
#   OAUTH_REDIRECT_URI=https://app.example.com/auth/callback

# Issuer URL — the `iss` claim on tokens. See the recipe above.
OAUTH_ISSUER_URL=

# OAuth 2.0 client ID issued by the IdP for THIS deployment.
OAUTH_CLIENT_ID=

# OAuth 2.0 client secret. (secret)
OAUTH_CLIENT_SECRET=

# Where the IdP redirects after authentication. Must match a URI
# registered with the OAuth client. Example:
# `https://app.example.com/auth/callback`.
OAUTH_REDIRECT_URI=

# Optional JWKS endpoint. If unset, the workspace fetches the issuer's
# OIDC discovery document and reads `jwks_uri` from there.
# OIDC_JWKS_URL=

# Symmetric HS256 signing secret. Used only by the Keycloak realm in
# KIND for fast local-dev token rotation; production uses RS256 via
# JWKS. (secret)
# OIDC_HS256_SECRET=

# Set to `true` or `1` to bypass OIDC entirely (host-side dev only).
# Refused at startup by `enforce_prod_invariants` — a deploy may never
# turn the bearer-token verifier into an open pass-through.
# OIDC_DISABLED=false

# Expected `aud` and `iss` on bearer JWTs (the `/mcp` + `/api` path).
# When set, the bearer verifier pins them so a token minted for a
# different client of the same IdP is rejected (token-confusion defense).
# Leave unset only for dev; production should pin both. `OIDC_AUDIENCE`
# is the OAuth client_id; `OIDC_ISSUER` is the IdP issuer URL.
# OIDC_AUDIENCE=
# OIDC_ISSUER=

# CSRF + session cookie signing key. Must be at least 32 bytes of
# entropy; rotating it invalidates every active session. (secret)
SESSION_SECRET=

# Operator bootstrap admin. The OAuth callback JIT-creates exactly this
# one identity as an `admin` on first login — the carve-out so a fresh
# deploy is never locked out. Every other unseeded identity is rejected
# (sign-up is operator-mediated). Leave empty to disable the carve-out.
# NAVIGATOR_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Email/password front door via GCP Identity Platform (opt-in). When set,
# `/auth/login` renders an email/password form alongside the OIDC button,
# and `POST /auth/password` validates the password against Identity
# Platform's `accounts:signInWithPassword` over TLS. Navigator NEVER
# stores or hashes a password — Google owns the credential, the reset
# flow, and lockout. This is the project's Identity Platform *browser*
# API key (not an admin credential). Leave empty to keep `/auth/login` a
# pure OIDC redirect. The resolved session is the same signed
# `SessionData` cookie either way. (secret)
# NAVIGATOR_IDENTITY_PLATFORM_API_KEY=
# Override the Identity Toolkit REST base (test seam). Default:
# `https://identitytoolkit.googleapis.com`.
# NAVIGATOR_IDENTITY_PLATFORM_ENDPOINT=

# Self-service password reset + email confirmation (for email/password,
# i.e. non-Google, users) reach Identity Platform's ADMIN surface to set a
# new password or mark an email verified — operations the public browser
# API key above can't perform. The admin call authenticates with a
# service-account bearer token minted from the GCE metadata server (no GCP
# SDK in `web`); on the reference deploy `web` runs as a Workload-Identity
# GSA granted `roles/identitytoolkit.admin`. These flows mount only when
# the password door above is on AND NAVIGATOR_GCP_PROJECT_ID (below) is
# set; the reset email itself ships through SendGrid like every other
# transactional email. Override the metadata server only in tests:
# # NAVIGATOR_GCP_METADATA_ENDPOINT=http://metadata.google.internal

# ---------------------------------------------------------------------
# Google OAuth access-token validation — the `/mcp` and A2A surfaces
# ---------------------------------------------------------------------

# Comma-separated list of OAuth client IDs allowed to call `/mcp` and
# `/api/aida/rpc`. Used to accept opaque `ya29.*` access tokens from
# Gemini Enterprise / Claude.ai. Leave empty to accept any caller the
# tokeninfo endpoint approves.
GOOGLE_OAUTH_CLIENT_IDS=

# Required workspace domain (the `hd` claim) on incoming Google OAuth
# tokens. Reject tokens that don't carry this `hd`. Example:
# `example.com`. Leave empty to skip the hd check.
GOOGLE_OAUTH_REQUIRED_HD=

# Override Google's tokeninfo endpoint (test seam). Default:
# `https://oauth2.googleapis.com/tokeninfo`.
# GOOGLE_TOKENINFO_URL=

# Override the GCE metadata server URL (test seam). Default:
# `http://metadata.google.internal`.
# GOOGLE_METADATA_URL=

# ---------------------------------------------------------------------
# OPA — authorization decision point
# ---------------------------------------------------------------------

# OPA URL. Without this, the policy client falls back to allow-all
# passthrough — fine for KIND, refused in prod. Example:
# `http://opa.navigator.svc.cluster.local:8181`.
NAVIGATOR_OPA_URL=

# Per-IP request budget per minute on the abuse-sensitive endpoints
# (/auth/*, /mcp, /api/aida/rpc). Unset → defaults to 60/min. Set to `0`
# to disable (e.g. when the edge WAF/Cloud Armor already rate-limits).
# NAVIGATOR_RATE_LIMIT_PER_MIN=60

# ---------------------------------------------------------------------
# Restate — durable workflow runtime
# ---------------------------------------------------------------------

# Restate broker URL. KIND: in-cluster Restate Operator service.
# Production: Restate Cloud ingress URL.
RESTATE_BROKER_URL=

# Restate Cloud auth token (secret). Not needed for the in-cluster
# operator in KIND.
# RESTATE_AUTH_TOKEN=

# Restate service name registered with the broker. Default:
# `workflows`.
# RESTATE_SERVICE=workflows

# TCP address the worker binary binds to so Restate can dial it.
# Default: `0.0.0.0:9080`.
# WORKFLOWS_SERVICE_LISTEN=0.0.0.0:9080

# URL the CLI / web crate uses to reach the Restate worker for
# admin operations (deployment registration, invocation listing).
# NAVIGATOR_WORKFLOWS_URL=https://workflows.example.com

# Restate Cloud admin API endpoint + token. When BOTH are set,
# `power-push` step 7d (and `navigator restate register`) re-registers the
# worker via the admin REST API directly, instead of the `restate` CLI —
# headless, needs no `restate cloud env configure` (which requires a TTY),
# and works with a non-expiring admin-scoped API key. Find the admin URL in
# the Restate Cloud console (DescribeEnvironment `adminBaseUrl`, port :9070);
# RESTATE_ADMIN_TOKEN must be an admin-scoped API key, NOT the ingress key.
# Unset → fall back to the `restate` CLI (KIND dev loop / fresh SSO token).
# RESTATE_ADMIN_URL=https://your-env.env.us.restate.cloud:9070
# RESTATE_ADMIN_TOKEN=

# OpenTelemetry — one seam for every binary (`telemetry::init`). When
# OTEL_EXPORTER_OTLP_ENDPOINT is set, binaries log JSON to stdout (so Cloud
# Logging -> BigQuery parses every field) and export OTLP traces + metrics to
# the collector at this address; unset means human-readable stdout only and no
# OTLP (dev / CI / OSS forks pay zero cost). See docs/observability.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.navigator.svc.cluster.local:4317
# OTEL_SERVICE_NAME overrides the per-binary default (navigator-web, etc.).
# OTEL_SERVICE_NAME=

# Base URL of this environment's Restate Cloud console. When set, the
# Archives and Heartbeat diagnostic emails deep-link the operator to the
# Invocations view for the failing/healthy run. Find it in the Restate
# Cloud console for your env.
# RESTATE_CLOUD_CONSOLE_URL=https://your-env.env.us.restate.cloud

# Recipient of the six-hourly durable-execution Heartbeat email (the
# liveness canary). Defaults to nick@neonlaw.com. Env-pinned to firm ops —
# never a client address.
# HEARTBEAT_NOTIFY_EMAIL=nick@neonlaw.com

# ---------------------------------------------------------------------
# Email — SendGrid (prod) or in-memory (KIND, tests)
# ---------------------------------------------------------------------

# `sendgrid` for the bare-SendGrid backend; anything else routes to
# the in-memory `CapturingEmail` so nothing leaves the binary.
# Production refuses anything but `sendgrid`.
NAVIGATOR_EMAIL_BACKEND=sendgrid

# SendGrid API key. (secret)
SENDGRID_API_KEY=

# From: address for outbound mail. Example: `noreply@example.com`.
SENDGRID_FROM_EMAIL=

# Shared secret embedded in the SendGrid Inbound Parse webhook URL
# (`/webhook/sendgrid/inbound/<secret>`). Without it, anyone on the
# internet can forge inbound mail into the mailroom. (secret)
SENDGRID_INBOUND_SECRET=

# Shared secret embedded in the SendGrid Event Webhook URL
# (`/api/email-events/<secret>`), which lands delivery events as
# Parquet on GCS for BigQuery. Without it, anyone could POST forged
# delivery events into the lake. See docs/email-events-pipeline.md.
# (secret)
SENDGRID_EVENTS_SECRET=

# SendGrid "Signed Event Webhook" verification key — the ECDSA/P-256
# public key SendGrid issues, base64-encoded DER SubjectPublicKeyInfo
# (the value the SendGrid Mail Settings → Signed Event Webhook screen
# shows). The Event Webhook verifies each delivery POST's signature over
# `timestamp || body` against this key, so a leaked endpoint URL alone
# cannot forge events. Required in production. (public key, not a secret)
SENDGRID_EVENTS_PUBLIC_KEY=

# Email-threading ("headless Front"). Both must be set to turn inbound
# support email into threaded conversations; if either is empty the
# webhook only archives the raw message. NAVIGATOR_PARSE_HOST is the
# subdomain whose MX points at SendGrid Inbound Parse — it is the host of
# every Reply-To token address (`c<token>@<parse_host>`).
# NAVIGATOR_STAFF_NOTIFY_EMAIL is the cockpit inbox that gets notified of
# new support mail; a reply from that mailbox is relayed back to the
# external party. Example: `parse.example.com` and `you+support@example.com`.
NAVIGATOR_PARSE_HOST=
NAVIGATOR_STAFF_NOTIFY_EMAIL=

# Optional: firm domain a staff reply's DKIM verdict must pass for before
# the reply is trusted to relay to the client or fire a workflow command
# (`@approve` etc.). When set (e.g. `example.com`), a staff reply whose
# SendGrid `dkim` verdict is not `pass` for this domain is journaled but
# neither relayed nor executed — closing the forged-`From` + leaked-token
# hole on the privileged command channel. Leave empty to gate the channel
# on staff-sender + unguessable token alone (the pre-DKIM posture).
NAVIGATOR_DKIM_REQUIRE_DOMAIN=

# ---------------------------------------------------------------------
# E-signature — DocuSign
# ---------------------------------------------------------------------
# When DOCUSIGN_BASE_URL + DOCUSIGN_ACCOUNT_ID are set together with
# EITHER a JWT-grant key set (DOCUSIGN_INTEGRATION_KEY + DOCUSIGN_USER_ID
# + DOCUSIGN_PRIVATE_KEY) OR a static DOCUSIGN_ACCESS_TOKEN, `web` uses
# the real `DocuSignSignatureProvider` to send the rendered retainer for
# signature; otherwise it falls back to the in-process stub (KIND /
# local dev). JWT grant is preferred — the provider mints and refreshes
# short-lived tokens itself, so there is no 8-hour token to rotate. OSS
# forks plug in their own DocuSign account or swap the
# `SignatureProvider` impl entirely.

# DocuSign follows the third-party dev/prod convention (see "Conventions"
# at the top of this file): a SANDBOX (demo) app for local dev — pointing
# at demo.docusign.net / account-d.docusign.com, so test envelopes carry
# NO legal weight and never touch the production account — and a separate
# live app for production. Sandbox credentials go in `.env`, production
# credentials in `.env.production`; both use the same DOCUSIGN_* names
# below. Unconfigured → the in-process stub, which sends nothing real.
# Full setup runbook (where each ID lives in the console, consent, the
# live test): docs/docusign-esignature.md.

# eSignature REST base URL. Sandbox: `https://demo.docusign.net/restapi`;
# production is the account's assigned base URI.
DOCUSIGN_BASE_URL=

# DocuSign API account GUID.
DOCUSIGN_ACCOUNT_ID=

# --- Auth: JWT grant (preferred; self-refreshing) ---
# The app's Integration Key (OAuth client id, a GUID) from the DocuSign
# Apps & Keys page. This is the JWT `iss`. NOTE: it is NOT the OAuth
# "secret key" — supplying the secret here makes a token mint fail with
# `issuer_not_found`. JWT grant does not use the OAuth secret at all.
DOCUSIGN_INTEGRATION_KEY=
# The impersonated API user's GUID (the "API Username" / User ID on the
# same Apps & Keys page) — used as the JWT `sub`.
DOCUSIGN_USER_ID=
# RSA private-key PEM whose public half is uploaded to the integration
# key; needs one-time admin consent for `signature impersonation`.
# Multi-line — quote the value. (secret)
DOCUSIGN_PRIVATE_KEY=
# OAuth host. Optional — defaults to the demo host
# `https://account-d.docusign.com`; production is
# `https://account.docusign.com`.
DOCUSIGN_OAUTH_BASE=

# --- Auth: static token (fallback for a quick local/demo smoke test) ---
# OAuth bearer access token for the eSignature API; DocuSign expires it
# in ~8h. Ignored when the JWT-grant vars above are set. (secret)
DOCUSIGN_ACCESS_TOKEN=

# Envelope recipient (the signer). Optional — defaults to the firm's
# support inbox / "Neon Law".
DOCUSIGN_SIGNER_EMAIL=
DOCUSIGN_SIGNER_NAME=

# HMAC-SHA256 key DocuSign Connect signs each completion callback with.
# The `/webhook/esignature/<secret>` endpoint verifies the
# `X-DocuSign-Signature-1` header over the raw body before advancing a
# retainer to END — without it, anyone could forge a "completed"
# callback (the firm asserting a client signed when they did not).
# Required in production. (secret)
DOCUSIGN_HMAC_KEY=

# Optional coarse path token in the webhook URL
# (`/webhook/esignature/<secret>`); defense-in-depth on top of the HMAC.
DOCUSIGN_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Accounting / billing — Xero
# ---------------------------------------------------------------------
# When XERO_TENANT_ID is set together with EITHER a client-credentials
# pair (XERO_CLIENT_ID + XERO_CLIENT_SECRET) OR a static XERO_ACCESS_TOKEN,
# `web` uses the real `XeroBillingProvider` to raise the matter's flat-fee
# invoice; otherwise it falls back to the in-process stub (KIND / local
# dev). Client-credentials is preferred — the provider mints and refreshes
# short-lived tokens itself, so there is no 30-minute token to rotate. OSS
# forks plug in their own Xero custom connection or swap the
# `BillingProvider` impl entirely.

# Xero follows the third-party dev/prod convention (see "Conventions" at
# the top of this file and docs/third-party-integrations.md): a SANDBOX
# custom connection bound to the free Xero DEMO COMPANY for local dev — so
# test invoices carry NO ledger weight and never touch the live
# organisation — and a separate live custom connection for production.
# Sandbox credentials go in `.env`, production credentials in
# `.env.production`; both use the same XERO_* names below. Unconfigured →
# the in-process stub, which sends nothing real. NOTE: a custom connection
# is a paid, single-organisation app ($5/mo USD each); the demo company is
# the one free exception and is the right target for dev + CI.

# The connected organisation's id, sent as the `Xero-Tenant-Id` header on
# every Accounting API call. A custom connection binds to one org, so this
# is fixed per environment. Required to activate the real provider.
XERO_TENANT_ID=

# Xero Accounting API base. Optional — defaults to
# `https://api.xero.com/api.xro/2.0`.
XERO_BASE_URL=

# --- Auth: client-credentials (preferred; self-refreshing) ---
# The custom connection's Client ID and Client Secret from the Xero
# developer portal. The secret is shown once at creation. (secret)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Token endpoint. Optional — defaults to
# `https://identity.xero.com/connect/token`.
XERO_TOKEN_URL=
# Space-separated scopes to request; must also be granted on the custom
# connection. A custom connection grants granular scopes — the legacy
# parent `accounting.transactions` is not offered and minting fails with
# `invalid_scope` if requested. Optional — defaults to
# `accounting.contacts accounting.invoices`.
XERO_SCOPE=

# --- Auth: static token (fallback for a quick local/demo smoke test) ---
# OAuth bearer access token for the Accounting API; Xero expires it in
# ~30m. Ignored when the client-credentials vars above are set. (secret)
XERO_ACCESS_TOKEN=

# --- Live sandbox test only (CI alias) ---
# The gated live test (`web/tests/xero_sandbox.rs`, mint against the real
# demo-company connection) reads these first, then FALLS BACK to the
# canonical XERO_CLIENT_ID/XERO_CLIENT_SECRET above. So locally you only
# need the canonical vars (one demo connection drives both the dev app and
# the test); these SANDBOX names exist for CI (GitHub Actions secrets),
# where labelling the creds "sandbox" keeps demo isolated from any live
# XERO_*. The test self-skips when neither is set, so CI stays green on
# forks. Same shape as the runtime client-credentials vars. (secret)
XERO_SANDBOX_CLIENT_ID=
XERO_SANDBOX_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Telemetry — OpenTelemetry
# ---------------------------------------------------------------------

# OTLP gRPC endpoint. Leave unset to drop spans on the floor (default
# in dev / KIND). Example: `https://otel-collector.example.com:4317`.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Service name reported on every span. Default: `navigator-web`.
# OTEL_SERVICE_NAME=navigator-web

# ---------------------------------------------------------------------
# Content directories — markdown that `web` serves
# ---------------------------------------------------------------------

# Override these only if you keep content outside the source tree.
# Defaults point at the in-repo `web/content/` subdirs.
# NAVIGATOR_PUBLIC_DIR=web/public
# NAVIGATOR_BLOG_DIR=web/content/blog
# NAVIGATOR_WORKSHOPS_DIR=web/content/workshops
# NAVIGATOR_MARKETING_DIR=web/content/marketing
# NAVIGATOR_ABOUT_DIR=web/content/about

# ---------------------------------------------------------------------
# A2A natural-language router — Vertex AI Gemini Flash
# ---------------------------------------------------------------------

# GCP project for the Vertex AI router. Leave unset to use the
# `NullRouter` (returns "I don't route requests" — fine for KIND
# and OSS forks that don't ship LLM routing).
# NAVIGATOR_GCP_PROJECT_ID=YOUR_PROJECT_ID

# Vertex AI region. Must be a region where the chosen model is
# available. Example: `us-west4`.
# NAVIGATOR_GCP_LOCATION=YOUR_REGION

# Model name. Example: `gemini-2.5-flash`.
# NAVIGATOR_ROUTER_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------
# On-chain attestation — Neon Law Node (Solana)
# ---------------------------------------------------------------------
#
# Selects the backend for the `onchain__record_attestation` workflow
# step. `null` (or unset) uses the `NullAttestor`: the step still writes
# the durable local `attestations` row, but records NO transaction — the
# row stays `pending`, so no matter ever claims an on-chain record that
# does not exist. This is the default for KIND, tests, and any deploy
# that has not stood up a wallet. `solana` is reserved for the
# not-yet-shipped `SolanaAttestor` and currently errors at startup by
# design, so a deployer cannot silently believe attestations are going
# on-chain when they are not.
NAVIGATOR_ONCHAIN_BACKEND=null

# Solana RPC endpoint the `SolanaAttestor` will dial (e.g. a devnet or
# mainnet-beta URL). Unused while the backend is `null`.
# SOLANA_RPC_URL=

# Address of the deployed on-chain attestation program (the Anchor
# program that owns the per-notation attestation PDA). Unused while the
# backend is `null`.
# SOLANA_PROGRAM_ID=

# Reference to the firm signer keypair that pays fees and signs the
# attestation transaction. This is a custody-sensitive secret: in prod it
# resolves from Secret Manager / KMS, never a path on disk. Unused while
# the backend is `null`. (secret)
# SOLANA_SIGNER_SECRET=

# ---------------------------------------------------------------------
# `navigator` CLI KIND / local dev loop
# ---------------------------------------------------------------------
#
# Every knob the `navigator start-dev-server` / `deploy` / `down` KIND loop reads. All are
# optional: unset (or empty) each falls back to the default shown, so an
# empty `.env` reproduces the stock `cargo run -p cli -- start-dev-server` behavior.
# A fork plugs its own cluster name, namespace, overlays, and host ports
# in here and runs the same `navigator` CLI with no Rust edits.

# KIND cluster name (`kind create cluster --name`). Default: `navigator`.
# NAVIGATOR_KIND_CLUSTER=navigator

# Kubernetes namespace the `navigator` CLI applies into and port-forwards from. Same
# concept in KIND and GKE, so it has no provider prefix. Default:
# `navigator`.
# NAVIGATOR_K8S_NAMESPACE=navigator

# Kustomize overlay `navigator start-dev-server` applies (deps only, no in-cluster `web`).
# Default: `k8s/overlays/kind-deps`.
# NAVIGATOR_KIND_DEPS_OVERLAY=k8s/overlays/kind-deps

# Kustomize overlay `navigator deploy` applies (full local stack incl. web).
# Default: `k8s/overlays/kind`.
# NAVIGATOR_KIND_OVERLAY=k8s/overlays/kind

# Kustomize overlay `navigator kustomize-gke` renders for inspection.
# Default: `examples/deploy/k8s/gke`.
# NAVIGATOR_GKE_OVERLAY=examples/deploy/k8s/gke

# Host ports the locally-run `web` binary reaches in-cluster deps on.
# The first five are pure host-side `kubectl port-forward` choices —
# `LOCAL` is arbitrary, nothing in the cluster changes. Default ports
# avoid common host collisions (Postgres 15432, not 5432; Restate
# ingress 9080, not the KIND-ingress 8080).
# NAVIGATOR_KIND_POSTGRES_PORT=15432
# NAVIGATOR_KIND_RESTATE_INGRESS_PORT=9080
# NAVIGATOR_KIND_RESTATE_ADMIN_PORT=9070
# NAVIGATOR_KIND_OPA_PORT=8181
# NAVIGATOR_KIND_WEB_PORT=3001

# Keycloak (30080) and fake-gcs-server (30443) reach the host through
# `k8s/kind-config.yaml` `extraPortMappings`, which bind at cluster
# create time. Overriding either makes the `navigator` CLI render a temp kind-config
# with only the matching `hostPort:` substituted; the in-cluster
# NodePort stays fixed, so the Service manifests stay in sync.
# NAVIGATOR_KIND_KEYCLOAK_PORT=30080
# NAVIGATOR_KIND_FAKE_GCS_PORT=30443

# ---------------------------------------------------------------------
# `navigator gcp setup` — fresh-project provisioning
# ---------------------------------------------------------------------
#
# Used only by `navigator gcp setup`. All four are optional and default to
# generic names. Override if you need to coexist with existing
# resources in the target project.

# GKE cluster name created by `navigator gcp setup`. Default: `navigator`.
# NAVIGATOR_GKE_CLUSTER_NAME=navigator

# Path to your deployer-private kustomize overlay, with placeholders
# (YOUR_PROJECT_ID, your-domain.example, etc.) already substituted to
# real values. Consumed by the `power-push` skill's step 7a to apply
# manifest changes (env vars, volumes, sidecars) before bumping the
# image. Leave unset if you're on Config Sync / Argo / Flux — those
# controllers reconcile the overlay continuously and step 7a is
# redundant. See `.claude/skills/power-push/SKILL.md` §7.
# NAVIGATOR_GKE_OVERLAY_DIR=

# Cloud SQL instance name. Default: `navigator-pg`.
# NAVIGATOR_SQL_INSTANCE=navigator-pg

# VPC network name. Default: `navigator`.
# NAVIGATOR_VPC_NAME=navigator

# Static external IP reserved for the global HTTPS LB. Default:
# `navigator-gateway-ip`.
# NAVIGATOR_GATEWAY_IP_NAME=navigator-gateway-ip

# GCP project number (the numeric form). Required by IAP and a few
# Workload Identity bindings. Look it up with `gcloud projects
# describe YOUR_PROJECT_ID --format='value(projectNumber)'`.
# NAVIGATOR_GCP_PROJECT_NUMBER=YOUR_PROJECT_NUMBER

# ---------------------------------------------------------------------
# DNS — optional integration with DNSimple
# ---------------------------------------------------------------------
# Only consumed by the `navigator` CLI for the optional zone-setup command. Skip
# entirely if you manage DNS yourself.

# DNSIMPLE_ACCOUNT_ID=
# DNSIMPLE_API_TOKEN=                    # (secret)

# ---------------------------------------------------------------------
# BigQuery / archives export — nightly Postgres → Parquet → BigQuery
# ---------------------------------------------------------------------
# Required only by the `archives` binary. Skip if you don't run the
# nightly snapshot.

# BIGQUERY_PROJECT=YOUR_PROJECT_ID
# BIGQUERY_DATASET=navigator_bi
# ARCHIVES_FAKE_TOKEN=                   # (test-only — for `wiremock`)

# ---------------------------------------------------------------------
# Test seams
# ---------------------------------------------------------------------
# Used by the browser E2E and feature suites; safe to ignore in prod.
# WEBDRIVER_URL=http://localhost:4444
# WEBDRIVER_HEADED=0
# DEVX_GCP_FAKE_TOKEN=                   # (test-only — for `wiremock`)
